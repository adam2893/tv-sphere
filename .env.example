# TV Sphere Configuration
# Copy this file to .env and customize values

# Secret key for HMAC URL signing (REQUIRED - change this!)
PROXY_SECRET_KEY=your-super-secret-key-change-me

# Server port
PORT=8000

# Cache settings (in seconds)
CACHE_TIMEOUT=300
STREAM_CACHE_DURATION=1800

# Concurrency limits
MAX_CONCURRENT_RESOLVERS=2
MAX_GLOBAL_CONCURRENT_RESOLVERS=2

# Timeouts (in seconds)
STREAM_RESOLUTION_TIMEOUT=60
PER_EMBED_TIMEOUT=30

# Playwright settings
PLAYWRIGHT_LOCALE=en-US
PLAYWRIGHT_TIMEZONE=America/Chicago
